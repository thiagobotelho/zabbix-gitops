# Zabbix API / OpenShift
ZABBIX_NAMESPACE=zabbix
ZABBIX_ROUTE_NAME=zabbix
ZABBIX_API_URL=
ZABBIX_ADMIN_USER=Admin
ZABBIX_ADMIN_PASSWORD=

# Usuário técnico usado pelo Grafana Zabbix datasource.
GRAFANA_NAMESPACE=grafana
ZABBIX_GRAFANA_SECRET=zabbix-datasource
ZABBIX_GRAFANA_USER=grafana-datasource
ZABBIX_GRAFANA_PASSWORD=

# SAML via Keycloak. Em Zabbix 7.4 o método oficial suportado para SSO é SAML.
ZABBIX_ENABLE_SAML=true
KEYCLOAK_NAMESPACE=keycloak-dev
KEYCLOAK_ROUTE_NAME=keycloak
# Opcional. Se vazio, o script descobre pela Route do Keycloak.
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=observability
ZABBIX_SAML_ENTITY_ID=zabbix
# Opcional. Se vazio, o script descobre pela Route do Zabbix.
ZABBIX_BASE_URL=

# Monitores HTTP criados no Zabbix para o laboratório CRC.
ZABBIX_PROVISION_MONITORING=true
ARGOCD_NAMESPACE=openshift-gitops
ARGOCD_ROUTE_NAME=openshift-gitops-server
GRAFANA_ROUTE_NAME=grafana-route
OPENSHIFT_API_READYZ_URL=
ARGOCD_BASE_URL=
GRAFANA_BASE_URL=
