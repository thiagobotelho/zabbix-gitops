# Zabbix API / OpenShift
ZABBIX_NAMESPACE=zabbix
ZABBIX_ROUTE_NAME=zabbix
ZABBIX_API_URL=
ZABBIX_ADMIN_USER=Admin
ZABBIX_ADMIN_PASSWORD=

# Usuário técnico usado pelo Grafana Zabbix datasource.
GRAFANA_NAMESPACE=grafana
ZABBIX_GRAFANA_SECRET=zabbix-datasource
ZABBIX_GRAFANA_USER=grafana-datasource
ZABBIX_GRAFANA_PASSWORD=

# SAML via Keycloak. Em Zabbix 7.4 o método oficial suportado para SSO é SAML.
ZABBIX_ENABLE_SAML=true
ZABBIX_ENABLE_SAML_JIT=true
ZABBIX_ENABLE_SAML_SCIM=true
KEYCLOAK_NAMESPACE=keycloak-dev
KEYCLOAK_ROUTE_NAME=keycloak
# Opcional. Se vazio, o script descobre pela Route do Keycloak.
KEYCLOAK_BASE_URL=
KEYCLOAK_REALM=observability
ZABBIX_MANAGE_SAML_IDP_CERT=true
ZABBIX_SAML_IDP_CONFIGMAP=zabbix-saml-idp
ZABBIX_SAML_IDP_CERT_KEY=idp.crt
ZABBIX_RESTART_WEB_ON_IDP_CERT_CHANGE=true
ZABBIX_SAML_ENTITY_ID=zabbix
ZABBIX_SAML_LOGIN_ATTRIBUTE=username
ZABBIX_SAML_GROUP_ATTRIBUTE=groups
ZABBIX_SAML_FIRST_NAME_ATTRIBUTE=firstName
ZABBIX_SAML_LAST_NAME_ATTRIBUTE=lastName
ZABBIX_DISABLED_USER_GROUP="Disabled provisioned users"
# Opcional. Se vazio, o script descobre pela Route do Zabbix.
ZABBIX_BASE_URL=

# Monitores HTTP criados no Zabbix para o laboratório CRC.
ZABBIX_PROVISION_MONITORING=true
ZABBIX_PROVISION_AGENT=true
ZABBIX_PROVISION_KUBERNETES_TEMPLATES=true
ZABBIX_IMPORT_KUBERNETES_TEMPLATES=true
ZABBIX_KUBERNETES_TEMPLATE_RELEASE=7.4
ZABBIX_PROVISION_COMPONENT_TEMPLATES=true
ZABBIX_AGENT_HOST=openshift-local
ZABBIX_AGENT_VISIBLE_NAME="OpenShift Local"
ZABBIX_AGENT_DNS=zabbix-agent2
ZABBIX_AGENT_PORT=10050
ZABBIX_AGENT_TEMPLATE="Linux by Zabbix agent"
ZABBIX_DEFAULT_AGENT_HOST="Zabbix server"
ZABBIX_DEFAULT_AGENT_VISIBLE_NAME="Zabbix server"
ZABBIX_CLEANUP_LEGACY_OPENSHIFT_HOSTS=true
ZABBIX_COMPONENT_TEMPLATE_GROUP=Templates/Observability
ZABBIX_KUBERNETES_MONITOR_SECRET=zabbix-kubernetes-monitor-token
ZABBIX_KUBERNETES_API_URL=
ZABBIX_KUBERNETES_NODES_TEMPLATE="Kubernetes nodes by HTTP"
ZABBIX_KUBERNETES_CLUSTER_TEMPLATE="Kubernetes cluster state by HTTP"
ZABBIX_KUBERNETES_API_TEMPLATE="Kubernetes API server by HTTP"
ZABBIX_KUBERNETES_KUBELET_TEMPLATE="Kubernetes Kubelet by HTTP"
ZABBIX_KUBERNETES_CONTROLLER_TEMPLATE="Kubernetes Controller manager by HTTP"
ZABBIX_KUBERNETES_SCHEDULER_TEMPLATE="Kubernetes Scheduler by HTTP"
ZABBIX_KUBERNETES_NODES_ENDPOINT_NAME=zabbix-agent2
ZABBIX_KUBE_NODE_MATCHES=.*
ZABBIX_KUBE_NAMESPACE_MATCHES="^(default|kube-.+|openshift-.+|argocd|openshift-gitops|grafana|zabbix|keycloak.*|tempo|loki|pyroscope|observability.*)$"
ARGOCD_NAMESPACE=openshift-gitops
ARGOCD_ROUTE_NAME=openshift-gitops-server
GRAFANA_ROUTE_NAME=grafana-route
OPENSHIFT_API_READYZ_URL=
ARGOCD_BASE_URL=
GRAFANA_BASE_URL=
PYROSCOPE_READY_URL=http://pyroscope.pyroscope.svc:4040/ready
PROMETHEUS_APPS_READY_URL=http://apps-monitoring-prometheus.observability-apps.svc:9090/-/ready
